{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "crons": [
    {
      "path": "/api/whatsapp/cron",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/whatsapp/proxima-luta-cron",
      "schedule": "*/2 * * * *"
    }
  ]
}
