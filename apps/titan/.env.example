# =============================================================================
# Titan — variáveis de ambiente (copie para .env.local e preencha)
# =============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Projeto LRSJ: risvafrrbnozyjquxvzi
NEXT_PUBLIC_SUPABASE_URL=https://risvafrrbnozyjquxvzi.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role (NUNCA commitar — usar Vercel/Supabase secrets em prod)
SUPABASE_SERVICE_ROLE_KEY=

# ── App base ─────────────────────────────────────────────────────────────────
# Usados para gerar links de email (reset de senha, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# ── Bootstrap inicial (uso único, deixe vazio em produção) ───────────────────
# Quando setado, /api/admin/set-master-access aceita header
# x-admin-bootstrap-secret: <valor> para criar o primeiro master.
# Após o primeiro master existir, remova essa variável.
ADMIN_BOOTSTRAP_SECRET=

# ── Vercel Cron (jobs internos) ─────────────────────────────────────────────
# Secret que os endpoints de cron exigem em x-cron-secret.
CRON_SECRET=

# ── WhatsApp (Meta Business Cloud API) ──────────────────────────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=

# ── WhatsApp (Evolution API, alternativa self-hosted) ───────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=

# ── Email transacional (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="LRSJ <no-reply@lrsj.com.br>"

# ── Safe2Pay (gateway de pagamento) ─────────────────────────────────────────
# Usado quando a federação/academia não tem credenciais próprias salvas
# em academias.safe2pay_api_key.
SAFE2PAY_API_KEY=
SAFE2PAY_TOKEN=

# ── Profep MAX (SSO Titan → Profep) ─────────────────────────────────────────
NEXT_PUBLIC_PROFEP_URL=https://profepmax.com.br
# Segredo HMAC compartilhado entre Titan e Profep para validar SSO.
TITAN_SSO_SECRET=

# ── Coordenação operacional ──────────────────────────────────────────────────
# Telefone do coordenador da federação (recebe notificações de novas filiações).
FEDERATION_COORD_PHONE=+5551999999999

# ── Debug ────────────────────────────────────────────────────────────────────
# Quando 'true', endpoints de webhook logam corpo do evento (use só em dev).
DEBUG_WEBHOOKS=
